{
  "name": "Portfolio Dev Container",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "biomejs.biome",
        "bradlc.vscode-tailwindcss",
        "dsznajder.es7-react-js-snippets",
        "mkhl.direnv"
      ]
    }
  },
  "remoteUser": "node",
  "postCreateCommand": "cd app && npm install",
  "forwardPorts": [5173]
}
